{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Capability for the main window",
    "windows": ["main"],
    "permissions": [
        "fs:allow-read-text-file",
        {
            "identifier": "fs:scope",
            "allow": ["$HOME/**"]
        },
        "fs:allow-write-text-file",
        { "identifier": "fs:scope-temp", "allow": [{ "path": "$TEMP/**" }] },
        "dialog:allow-open",
        "core:default",
        "opener:default"
    ]
}
